export component CustomTextBar inherits Rectangle {
    // Expose the text property to the outside world
    in-out property <string> text <=> input.text;
    in property <string> placeholder: "Enter record name...";

    // Styling the container box
    background: #1a1a1a;
    border-radius: 8px;
    border-width: 1px;
    border-color: input.has-focus ? #00e676 : #333333; // Green glow on focus
    height: 45px;
    
    // Clicking anywhere on this box focuses the cursor
    forward-focus: input; 

    animate border-color { duration: 100ms; }

    // Layout for the text inside the box
    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        alignment: start;

        // Using a FocusScope + TouchArea stack to handle placeholder visibility
        FocusScope {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            
            // 1. The Placeholder Text (Only shows when input is empty)
            if input.text == "" : Text {
                text: root.placeholder;
                color: #666666;
                font-size: 15px;
                vertical-alignment: center;
            }

            // 2. The Core Interactive Text Input
            input := TextInput {
                width: 100%;
                height: 100%;
                font-size: 15px;
                color: #ffffff;
                vertical-alignment: center;
                single-line: true; // Keeps it as a single line entry bar
                
                // Triggers when the user presses 'Enter'
                accepted => {
                    root.accepted();
                }
            }
        }
    }

    // Callback so your main app knows when Enter was pressed
    callback accepted();
}