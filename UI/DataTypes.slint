export struct List { lval: string, rval: string }

export struct Date-Detail {
    date: string,
    data: [List],
}

export struct Goal-Detail {
    name: string,
    date: string,
    time: string,
    total: float,
    saved: float,
}

export struct Record-Detail {
    name: string,
    date: string,
    time: string,
    category: string,
    amount: float,
}
