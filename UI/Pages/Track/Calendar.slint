import { Theme as T } from "../../Theme.slint";
import { Header, LR-Gapped-Item } from "../../Components/Components.slint";
import {
    ExpenseItem,
    DayExpenses,
    Detail-Daily-Expense,
} from "DailyExpense.slint";





component Track-Calendar-Item inherits Rectangle {
    in property <ExpenseItem> data;

    property <color> positive: #15ff00;
    property <color> negative: #ff0000;

    background: data.amount > 0 ? positive.with-alpha(0.1) : negative.with-alpha(0.1);
    border-radius: T.bor-radius / 2;
    border-width: 1px;

    HorizontalLayout {
        padding-left: T.gap / 2;
        padding-right: self.padding-left;
        padding-top: T.gap / 4;
        padding-bottom: self.padding-top;

        spacing: T.gap / 2;
        alignment: space-between;

        Text {
            text: data.name;
            font-size: T.font5;
            color: T.fg2;
            horizontal-alignment: left;
            vertical-alignment: center;
            overflow: elide;
        }

        Text {
            text: data.amount > 0 ? data.amount : abs(data.amount);
            font-size: T.font5;
            color: data.amount > 0 ? #10bb00 : #c80000;
            horizontal-alignment: right;
            vertical-alignment: center;
        }
    }
}


export component Track-Calendar inherits Rectangle {

    in property <[[DayExpenses]]> data: [
        // Week 1
        [
            { items: [{ name: "Parents Allowance", amount: 500 }, { name: "Bus Fare", amount: -30 }] },
            { items: [{ name: "College Lunch", amount: -60 }] },
            {
                items: [
                    { name: "Metro Recharge", amount: -100 },
                    { name: "Snacks", amount: -40 },
                    { name: "Stationery", amount: -25 }
                ]
            },
            { items: [{ name: "Coffee", amount: -50 }] },
            { items: [{ name: "Auto Rickshaw", amount: -40 }, { name: "Canteen", amount: -55 }] },
            { items: [{ name: "Movie Ticket", amount: -180 }] },
            { items: [{ name: "Weekend Treats", amount: -120 }, { name: "Bike Fuel", amount: -100 }] }
        ],

        // Week 2
        [
            { items: [{ name: "Parents Allowance", amount: 500 }] },
            { items: [{ name: "Printouts", amount: -15 }, { name: "Bus Fare", amount: -30 }] },
            { items: [{ name: "Subway Combo", amount: -140 }] },
            {
                items: [
                    { name: "Metro Ride", amount: -35 },
                    { name: "Tea", amount: -15 },
                    { name: "Book Purchase", amount: -200 }
                ]
            },
            { items: [{ name: "College Lunch", amount: -50 }] },
            { items: [{ name: "Auto Rickshaw", amount: -40 }] },
            { items: [{ name: "Snacks", amount: -45 }, { name: "Freelance Gig", amount: 300 }] }
        ],

        // Week 3
        [
            { items: [{ name: "Parents Allowance", amount: 500 }, { name: "Bus Fare", amount: -30 }] },
            { items: [{ name: "Burger", amount: -80 }] },
            { items: [{ name: "Metro Ride", amount: -35 }, { name: "Notebook", amount: -40 }] },
            { items: [{ name: "College Lunch", amount: -60 }, { name: "Ice Cream", amount: -30 }] },
            { items: [{ name: "Auto Rickshaw", amount: -40 }] },
            { items: [{ name: "Pizza with Friends", amount: -250 }, { name: "E-way Bill", amount: -20 }] },
            { items: [{ name: "Laundry", amount: -80 }] }
        ],

        // Week 4
        [
            { items: [{ name: "Parents Allowance", amount: 500 }] },
            { items: [{ name: "Bus Fare", amount: -30 }, { name: "Canteen Juice", amount: -25 }] },
            { items: [{ name: "Metro Recharge", amount: -100 }] },
            {
                items: [
                    { name: "College Lunch", amount: -55 },
                    { name: "Photocopies", amount: -12 },
                    { name: "Tea", amount: -15 }
                ]
            },
            { items: [{ name: "Auto Rickshaw", amount: -40 }] },
            { items: [{ name: "Snacks", amount: -50 }] },
            { items: [{ name: "Gift for Friend", amount: -150 }] }
        ],

        // Week 5
        [
            { items: [{ name: "Parents Allowance", amount: 500 }, { name: "Bus Fare", amount: -30 }] },
            { items: [{ name: "College Lunch", amount: -60 }] },
            { items: [{ name: "Parents Allowance", amount: 500 }, { name: "Bus Fare", amount: -30 }] },
            { items: [{ name: "College Lunch", amount: -60 }] },
            { items: [{ name: "Parents Allowance", amount: 500 }, { name: "Bus Fare", amount: -30 }] },
            { items: [{ name: "College Lunch", amount: -60 }] },
            { items: [{ name: "Parents Allowance", amount: 500 }, { name: "Bus Fare", amount: -30 }] },
        ]
    ];

    private property <{ row: int, col: int }> selected;

    border-radius: 10px;
    border-color: T.bor-color;
    border-width: 1px;
    clip: true;

    GridLayout {
        property <[string]> columns: 
            ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

        Row {
            for column in columns: Rectangle {
                background: T.bg2;
                border-width: 1px;
                border-color: T.bor-color;

                HorizontalLayout {
                    padding: T.gap;

                    Text {
                        text: column;
                        font-size: T.font4;
                        color: T.fg1;
                        vertical-alignment: center;
                        horizontal-alignment: center;

                        height: self.preferred-height;
                    }
                }
            }
        }

        for row[row-in] in data: Row {
            for element[col-in] in row: Rectangle {

                border-width: 1px;
                border-color: tile-detail.is-open ? #00eeff : T.bg3;

                cell := Rectangle {

                    border-width: 1px;
                    border-color: T.bor-color.with-alpha(0.2);

                    Flickable {
                        VerticalLayout {
                            alignment: start;
                            spacing: T.gap / 2;
                            padding: T.gap * 0.75;

                            for item in element.items: Track-Calendar-Item {
                                data: item;
                            }
                        }
                    }
                }

                touch := TouchArea {
                    clicked => {
                        selected = { row: row-in, col: col-in };
                        tile-detail.show();
                    }
                }

                Rectangle {
                    visible: !touch.has-hover;
                    border-radius: 5px;
                    height: 25px;
                    width: self.height;
                    x: cell.width - self.width - T.gap / 2;
                    y: cell.height - self.height - T.gap / 2;

                    background: T.fg3;
                    animate background { duration: 200ms; }

                    Text {
                        text: (row-in) * 7 + (col-in + 1);
                        font-weight: 800;

                        color: { if touch.has-hover { transparent } else { T.bg1 } };
                        animate color { duration: 200ms; }
                    }
                }

                tile-detail := PopupWindow {
                    close-policy: close-on-click-outside;

                    height: min(expense.preferred-height, 400px);
                    width: expense.preferred-width;

                    x: (parent.x + parent.width + self.preferred-width > root.width) ?
                        parent.width / 2 - self.preferred-width :
                        parent.width / 2;

                    y: (parent.y + parent.height + self.preferred-height < root.height + T.gap * 2) ?
                        parent.height / 2 :
                        parent.height / 2 - self.preferred-height;

                    expense := Detail-Daily-Expense {
                        data: root.data[selected.row][selected.col];
                    }
                }
            }
        }
    }
}
